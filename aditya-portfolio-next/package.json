    "@types/react-dom": "^19",
    "eslint": "^9",
    "cross-env": "^7.0.3",
    "eslint-config-next": "16.2.4",
    "gh-pages": "^6.3.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
